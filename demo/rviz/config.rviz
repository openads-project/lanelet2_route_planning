    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Route1
      Splitter Ratio: 0.5
    Tree Height: 878
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
